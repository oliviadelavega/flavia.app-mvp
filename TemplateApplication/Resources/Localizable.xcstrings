    "Daily check-in" : {

    },
    "Daily Symptoms" : {

    },
    "DATA_OVERVIEW_AREA1_DESCRIPTION" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tägliche Check-ins erfassen Juckreiz, Schweregrad, Stress, betroffene Körperstellen, verwendete Salben und Notizen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quick daily check-ins capture itch, severity, stress, affected body parts, topicals used, and notes."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dagliga incheckningar fångar klåda, svårighetsgrad, stress, drabbade kroppsdelar, salvor och anteckningar."
          }
        }
      }
    },
    "DATA_OVERVIEW_AREA2_DESCRIPTION" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mahlzeiten per Sprache oder Text protokollieren. Automatische Markierung erkennt häufige Auslöser wie Milchprodukte, Gluten oder Nüsse."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Log meals by voice or text. Automatic tagging spots common triggers like dairy, gluten, or nuts."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Logga måltider med röst eller text. Automatisk märkning hittar vanliga utlösare som mejeri, gluten eller nötter."
          }
        }
      }
    },
    "DATA_OVERVIEW_AREA3_DESCRIPTION" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Herzfrequenz, HRV, Schlaf, Körpertemperatur und Aktivität fließen aus Apple Watch, Whoop oder Oura über Apple Health ein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heart rate, HRV, sleep, body temperature, and activity flow in from Apple Watch, Whoop, or Oura via Apple Health."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puls, HRV, sömn, kroppstemperatur och aktivitet flödar in från Apple Watch, Whoop eller Oura via Apple Health."
          }
        }
      }
    },
    "DATA_OVERVIEW_AREA4_DESCRIPTION" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standortbasierter UV-Index, Luftqualität, Pollen und Wetter werden aktualisiert, während du dich bewegst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Location-based UV index, air quality, pollen, and weather are updated as you move through your day."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Platsbaserat UV-index, luftkvalitet, pollen och väder uppdateras medan du rör dig."
          }
        }
      }
    },
    "DATA_OVERVIEW_SUBTITLE" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Flavia ist dein Begleiter bei Ekzemen. Wir verbinden tägliche Check-ins, Mahlzeiten, Wearable-Daten und deine Umgebung, um Schübe vorherzusagen und zu erklären."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Flavia is your eczema companion. We combine daily check-ins, meals, wearable data, and your environment to help predict and explain flare-ups."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Flavia är din eksemkompanjon. Vi kombinerar dagliga incheckningar, måltider, wearable-data och din omgivning för att förutsäga och förklara skov."
          }
        }
      }
    },
